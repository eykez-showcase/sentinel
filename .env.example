# App
APP_ENV=development

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/sentinel

# Camera
DEFAULT_FRAME_RATE=10

# YOLO
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_DEVICE=cpu

# Zones / property map
PROPERTY_CONFIG_PATH=config/property.yaml

# Event thresholds
LOITERING_THRESHOLD_SECONDS=30

# AI reasoning — set AI_PROVIDER to "anthropic" or "openai"
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
AI_SUMMARY_MAX_EVENTS=20

# WebSocket
WS_HEARTBEAT_INTERVAL=30
